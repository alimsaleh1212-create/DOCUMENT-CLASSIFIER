# Vault — the ONLY real secret in this file
VAULT_TOKEN=dev-root-token
VAULT_ADDR=http://localhost:8200

# ── Infrastructure container credentials ─────────────────────────────────────
# These seed the Postgres, MinIO, SFTP, and Vault containers themselves.
# vault-init.sh reads them and writes them into Vault; the API/worker then
# fetch from Vault — they never read these variables directly.
POSTGRES_USER=docclass
POSTGRES_PASSWORD=change-me-in-production
POSTGRES_DB=docclass

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-in-production

SFTP_USER=docscanner
SFTP_PASSWORD=change-me-in-production

JWT_SIGNING_KEY=change-me-in-production

# ── Host ports (compose maps these to container standard ports) ───────────────
API_PORT=8000
FRONTEND_DEV_PORT=5173
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
SFTP_PORT=2222
DB_PORT=5432
REDIS_PORT=6379

# Do NOT put real secrets here.
# All secrets resolve from Vault at app startup.
# Run: grep -ri 'password' backend/app/  — must return zero hits outside vault.py